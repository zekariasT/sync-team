{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Backend (NestJS)",
            "type": "node-terminal",
            "request": "launch",
            "command": "cd backend && bun run start:dev",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug Frontend (Next.js)",
            "type": "node-terminal",
            "request": "launch",
            "command": "cd frontend && bun run dev",
            "cwd": "${workspaceFolder}",
            "serverReadyAction": {
                "pattern": "started server on",
                "action": "debugWithChrome",
                "webRoot": "${workspaceFolder}/frontend"
            }
        }
    ],
    "compounds": [
        {
            "name": "Full Stack Debug",
            "configurations": [
                "Debug Backend (NestJS)",
                "Debug Frontend (Next.js)"
            ]
        }
    ]
}