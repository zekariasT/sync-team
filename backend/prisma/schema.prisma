// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  avatar         String?
  status         String          @default("Available")
  timezone       String          @default("UTC")
  teamMembers    TeamMember[]
  sentMessages   Message[]       @relation("SentMessages")
  sentDMs        DirectMessage[] @relation("SentDMs")
  receivedDMs    DirectMessage[] @relation("ReceivedDMs")
  sentVideos     VideoMessage[]  @relation("SentVideos")
  videoReactions VideoReaction[]
  assignedTasks     Task[]          @relation("AssignedTasks")
  reportedTasks     Task[]          @relation("ReportedTasks")
  uploadedDocuments Document[]      @relation("UploadedDocuments")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model Team {
  id          String         @id @default(cuid())
  name        String
  description String?
  members     TeamMember[]
  channels    Channel[]
  videos      VideoMessage[]
  projects    Project[]
  cycles      Cycle[]
  tasks       Task[]
  documents   Document[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

enum Role {
  ADMIN
  LEAD
  MEMBER
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      Role     @default(MEMBER)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, teamId])
}

enum ChannelType {
  GENERAL
  ANNOUNCEMENT
  TOPIC
}

model Channel {
  id        String      @id @default(cuid())
  teamId    String
  name      String
  type      ChannelType @default(GENERAL)
  team      Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  channelId String
  senderId  String
  content   String   @db.Text
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender    User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DirectMessage {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String   @db.Text
  sender     User     @relation("SentDMs", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedDMs", fields: [receiverId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// --- Loom-style Async Video Messaging ---

model VideoMessage {
  id          String          @id @default(cuid())
  teamId      String
  senderId    String
  title       String?
  videoUrl    String          // Cloudinary URL
  duration    Float?          // seconds
  transcript  String?         @db.Text
  team        Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sender      User            @relation("SentVideos", fields: [senderId], references: [id], onDelete: Cascade)
  reactions   VideoReaction[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model VideoReaction {
  id          String       @id @default(cuid())
  videoId     String
  userId      String
  timestamp   Float        // Seconds into the video
  emoji       String?
  comment     String?      @db.Text
  video       VideoMessage @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
}

// --- Linear-style Task & Issue Tracking ---

enum TaskState {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

model Project {
  id          String   @id @default(cuid())
  teamId      String
  name        String
  description String?  @db.Text
  tasks       Task[]
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Cycle {
  id          String   @id @default(cuid())
  teamId      String
  name        String
  startDate   DateTime
  endDate     DateTime
  tasks       Task[]
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Task {
  id          String    @id @default(cuid())
  teamId      String
  title       String
  description String?   @db.Text
  state       TaskState @default(TODO)
  assigneeId  String?
  reporterId  String
  cycleId     String?
  projectId   String?
  
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignee    User?     @relation("AssignedTasks", fields: [assigneeId], references: [id])
  reporter    User      @relation("ReportedTasks", fields: [reporterId], references: [id])
  cycle       Cycle?    @relation(fields: [cycleId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// --- RAG Documentation Features ---

model Document {
  id          String   @id @default(cuid())
  teamId      String
  uploaderId  String
  title       String
  fileUrl     String   // URL to original document
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  uploader    User     @relation("UploadedDocuments", fields: [uploaderId], references: [id])
  createdAt   DateTime @default(now())
}
