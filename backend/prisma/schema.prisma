generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  name              String
  avatar            String?
  status            String          @default("Available")
  timezone          String          @default("UTC")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  receivedDMs       DirectMessage[] @relation("ReceivedDMs")
  sentDMs           DirectMessage[] @relation("SentDMs")
  uploadedDocuments Document[]      @relation("UploadedDocuments")
  sentMessages      Message[]       @relation("SentMessages")
  assignedTasks     Task[]          @relation("AssignedTasks")
  reportedTasks     Task[]          @relation("ReportedTasks")
  teamMembers       TeamMember[]
  sentVideos        VideoMessage[]  @relation("SentVideos")
  videoReactions    VideoReaction[]
}

model Team {
  id          String         @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  channels    Channel[]
  cycles      Cycle[]
  documents   Document[]
  projects    Project[]
  tasks       Task[]
  members     TeamMember[]
  videos      VideoMessage[]
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId], map: "TeamMember_teamId_fkey")
}

model Channel {
  id        String      @id @default(cuid())
  teamId    String
  name      String
  type      ChannelType @default(GENERAL)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  team      Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([teamId], map: "Channel_teamId_fkey")
}

model Message {
  id        String   @id @default(cuid())
  channelId String
  senderId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender    User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([channelId], map: "Message_channelId_fkey")
  @@index([senderId], map: "Message_senderId_fkey")
}

model DirectMessage {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  receiver   User     @relation("ReceivedDMs", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentDMs", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([receiverId], map: "DirectMessage_receiverId_fkey")
  @@index([senderId], map: "DirectMessage_senderId_fkey")
}

model VideoMessage {
  id         String          @id @default(cuid())
  teamId     String
  senderId   String
  title      String?
  videoUrl   String
  duration   Float?
  transcript String?         @db.Text
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  sender     User            @relation("SentVideos", fields: [senderId], references: [id], onDelete: Cascade)
  team       Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  reactions  VideoReaction[]

  @@index([senderId], map: "VideoMessage_senderId_fkey")
  @@index([teamId], map: "VideoMessage_teamId_fkey")
}

model VideoReaction {
  id        String       @id @default(cuid())
  videoId   String
  userId    String
  timestamp Float
  emoji     String?
  comment   String?      @db.Text
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     VideoMessage @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([userId], map: "VideoReaction_userId_fkey")
  @@index([videoId], map: "VideoReaction_videoId_fkey")
}

model Project {
  id          String   @id @default(cuid())
  teamId      String
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([teamId], map: "Project_teamId_fkey")
}

model Cycle {
  id        String   @id @default(cuid())
  teamId    String
  name      String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([teamId], map: "Cycle_teamId_fkey")
}

model Task {
  id          String    @id @default(cuid())
  teamId      String
  title       String
  description String?   @db.Text
  state       TaskState @default(TODO)
  assigneeId  String?
  reporterId  String
  cycleId     String?
  projectId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  assignee    User?     @relation("AssignedTasks", fields: [assigneeId], references: [id])
  cycle       Cycle?    @relation(fields: [cycleId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id])
  reporter    User      @relation("ReportedTasks", fields: [reporterId], references: [id])
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([assigneeId], map: "Task_assigneeId_fkey")
  @@index([cycleId], map: "Task_cycleId_fkey")
  @@index([projectId], map: "Task_projectId_fkey")
  @@index([reporterId], map: "Task_reporterId_fkey")
  @@index([teamId], map: "Task_teamId_fkey")
}

model Document {
  id         String   @id @default(cuid())
  teamId     String
  uploaderId String
  title      String
  fileUrl    String
  createdAt  DateTime @default(now())
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  uploader   User     @relation("UploadedDocuments", fields: [uploaderId], references: [id])

  @@index([teamId], map: "Document_teamId_fkey")
  @@index([uploaderId], map: "Document_uploaderId_fkey")
}

enum Role {
  ADMIN
  LEAD
  MEMBER
}

enum ChannelType {
  GENERAL
  ANNOUNCEMENT
  TOPIC
}

enum TaskState {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}
